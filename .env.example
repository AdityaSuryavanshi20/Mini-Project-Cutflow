# CutFlow Environment Variables
# Copy to .env and fill in your own values (never commit the real .env file)

SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# Database
# Leave DB_NAME unset (or set USE_SQLITE=True) to use SQLite for local dev instead of MySQL.
USE_SQLITE=True
DB_NAME=cutflow_db
DB_USER=cutflow_user
DB_PASSWORD=change-this-password
DB_HOST=localhost
DB_PORT=3306

# Email (optional for dev – uses console backend when DEBUG=True)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=CutFlow <noreply@cutflow.com>

# Company
COMPANY_NAME=CutFlow Fenestration
